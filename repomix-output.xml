import getClientPromise from "@/lib/mongodb"
import { ObjectId } from "mongodb"
import { z } from "zod"

// Schema for simple note creation
const simpleNoteSchema = z.object({
  projectId: z.string().min(1),
  userEmail: z.string().email().optional(),
  title: z.string().min(1, "Title required"),
  content: z.string().optional().default(""),
})

// Schema for canvas snapshot
const canvasSnapshotSchema = z.object({
  projectId: z.string().min(1),
  userEmail: z.string().email().optional(),
  snapshot: z.object({
    notes: z.array(z.any()).optional().default([]),
    connections: z.array(z.any()).optional().default([]),
    camera: z.object({ x: z.number(), y: z.number() }).optional(),
    zoom: z.number().optional(),
  }),
})

export async function GET(req: Request) {
  const url = new URL(req.url)
  const projectId = url.searchParams.get("projectId")
  const userEmail = url.searchParams.get("userEmail")

  if (!projectId)
    return Response.json({ success: false, message: "projectId required" }, { status: 400 })

  const client = await getClientPromise()
  const db = client.db("hylithhub")

  const query: any = { projectId }
  if (userEmail) query.userEmail = userEmail

  const notes = await db.collection("simple_notes").find(query).sort({ createdAt: -1 }).toArray()

  return Response.json({
    success: true,
    data: notes.map(n => ({
      id: n._id.toString(),
      title: n.title,
      content: n.content,
      createdAt: n.createdAt,
      updatedAt: n.updatedAt,
    })),
  })
}

export async function POST(req: Request) {
  try {
    const body = await req.json()
    
    // Check if this is a canvas snapshot or a simple note
    if (body.snapshot) {
      // Handle canvas snapshot
      const parsed = canvasSnapshotSchema.parse(body)
      
      const client = await getClientPromise()
      const db = client.db("hylithhub")
      
      const now = new Date()
      const snapshotDoc = {
        ...parsed,
        createdAt: now,
        updatedAt: now,
      }
      
      // Upsert: update if exists, insert if not
      const existingSnapshot = await db.collection("notes").findOne({ 
        projectId: parsed.projectId, 
        userEmail: parsed.userEmail 
      })
      
      if (existingSnapshot) {
        // Update existing snapshot
        await db.collection("notes").updateOne(
          { _id: existingSnapshot._id },
          { $set: { ...snapshotDoc, updatedAt: now } }
        )
      } else {
        // Insert new snapshot
        await db.collection("notes").insertOne(snapshotDoc)
      }
      
      return Response.json({ success: true })
    } else {
      // Handle simple note
      const parsed = simpleNoteSchema.parse(body)
      
      const client = await getClientPromise()
      const db = client.db("hylithhub")
      
      const now = new Date()
      const result = await db.collection("simple_notes").insertOne({
        ...parsed,
        createdAt: now,
        updatedAt: now,
      })
      
      return Response.json({
        success: true,
        data: {
          id: result.insertedId.toString(),
          title: parsed.title,
          content: parsed.content,
          createdAt: now.toISOString(),
          updatedAt: now.toISOString(),
        },
      })
    }
  } catch (error) {
    if (error instanceof z.ZodError)
      return Response.json({ success: false, message: error.issues[0].message }, { status: 400 })
    console.error("Error in POST /api/notes:", error)
    return Response.json({ success: false, message: "Failed to create note" }, { status: 500 })
  }
}

export async function PUT(req: Request) {
  try {
    const body = await req.json()
    const { id, title, content } = body

    if (!id)
      return Response.json({ success: false, message: "id required" }, { status: 400 })

    const client = await getClientPromise()
    const db = client.db("hylithhub")

    await db.collection("simple_notes").updateOne(
      { _id: new ObjectId(id) },
      { $set: { title, content, updatedAt: new Date() } }
    )

    return Response.json({ success: true })
  } catch {
    return Response.json({ success: false, message: "Failed to update note" }, { status: 500 })
  }
}

export async function DELETE(req: Request) {
  const url = new URL(req.url)
  const id = url.searchParams.get("id")

  if (!id)
    return Response.json({ success: false, message: "id required" }, { status: 400 })

  const client = await getClientPromise()
  const db = client.db("hylithhub")

  await db.collection("simple_notes").deleteOne({ _id: new ObjectId(id) })

  return Response.json({ success: true })
}
